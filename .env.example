# Required: Secret key for proxy auth (clients send this as x-api-key)
SECRET_KEY=your-secret-key-here

# Required: OpenCode API key (get from https://opencode.ai)
OPENCODE_API_KEY=sk-opencode-api-key

# Optional: Override API base URL (used by Claude Code client to reach this proxy)
# ANTHROPIC_BASE_URL=https://opencode.ai

# Optional: Override OpenCode upstream base URL (defaults to https://opencode.ai)
# Useful when you want to route through a different OpenCode-compatible endpoint
# OPENCODE_BASE_URL=https://opencode.ai

# Optional: Fallback provider keys (for when OpenCode fails)
OPENAI_KEY=sk-openai-key
GEMINI_KEY=gemini-api-key
GROQ_API_KEY=gsk-groq-api-key
OPENROUTER_KEY=sk-or-openrouter-key
CEREBRAS_KEY=csk-cerebras-key
GITHUB_KEY=ghp-github-token
MISTRAL_KEY=mistral-api-key

# Optional: Model route overrides
# OPUS_MAP_MODEL=deepseek-v4-flash-free
# SONNET_MAP_MODEL=mimo-v2.5-free
# HAIKU_MAP_MODEL=north-mini-code-free

# Optional: HTTP proxy for upstream requests
# OPENCODE_PROXY=http://proxy:8080

# Server config
HOST=0.0.0.0
PORT=4000
